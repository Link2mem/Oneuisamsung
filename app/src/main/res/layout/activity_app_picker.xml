<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.layout.ToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:expanded="false"
    app:navigationIcon="@drawable/ic_oui_back"
    app:subtitle="Eternity Alarm"
    app:title="اختيار رنين المنبه">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <dev.oneuiproject.oneui.widget.RoundFrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="@color/oui_background_color">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="قائمة النغمات"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />

                <androidx.appcompat.widget.AppCompatSpinner
                    android:id="@+id/apppicker_spinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

        </dev.oneuiproject.oneui.widget.RoundFrameLayout>

        <dev.oneuiproject.oneui.widget.Separator
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <dev.oneuiproject.oneui.widget.RoundFrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.apppickerview.widget.AppPickerView
                android:id="@+id/apppicker_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/oui_background_color" />

            <androidx.appcompat.widget.SeslProgressBar
                android:id="@+id/apppicker_progress"
                style="@style/Widget.AppCompat.ProgressBar.Large"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center" />

        </dev.oneuiproject.oneui.widget.RoundFrameLayout>

    </LinearLayout>

</dev.oneuiproject.oneui.layout.ToolbarLayout>
