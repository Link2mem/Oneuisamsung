<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <FrameLayout
        android:id="@+id/cardview_main_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/cardview_divider"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sesl_list_divider_height"
            android:background="?attr/listDividerColor"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/cardview_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/listPreferredItemHeightSmall"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_gravity="center"
            android:gravity="center_vertical"
            android:background="?attr/listChoiceBackgroundIndicator"
            android:baselineAligned="false">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingEnd="16dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/cardview_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginVertical="12dp"
                    android:layout_gravity="center"
                    android:scaleType="centerInside"
                    android:tint="@color/oui_primary_color"
                    tools:src="@android:drawable/ic_lock_idle_alarm"
                    tools:ignore="ContentDescription,UseAppTint" />

            </FrameLayout>

            <RelativeLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/cardview_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="12dp"
                    android:textAppearance="?attr/textAppearanceListItem"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textAlignment="viewStart"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="07:00 AM"
                    tools:ignore="RtlSymmetry" />

                <TextView
                    android:id="@+id/cardview_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/cardview_title"
                    android:layout_alignStart="@id/cardview_title"
                    android:paddingEnd="12.0dip"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textAlignment="viewStart"
                    android:maxLines="2"
                    android:visibility="visible"
                    tools:text="Daily | Eternity Ringtone"
                    tools:ignore="RtlSymmetry" />

            </RelativeLayout>

        </LinearLayout>

    </FrameLayout>

</merge>
